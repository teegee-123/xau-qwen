{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist/tests",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "../src/*": ["backend/src/*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["tests/**/*.ts", "backend/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
